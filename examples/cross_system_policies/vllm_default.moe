version 0.6
# Phase 5.4: vLLM's default expert caching policy expressed in MoE-PolicyLang DSL
# vLLM uses simple LRU eviction with GPU-only execution.
#
# Reference: vLLM source, model_executor/layers/fused_moe
# Estimated hand-coded equivalent: ~60 LOC (Python) + ~200 LOC (C++ kernel)
#
# Status: STUB — verify against vLLM source during Phase 5

policy vllm_default {
    cache {
        capacity = 8
        eviction = lru
    }
    prefetch {
        strategy = none
    }
    schedule {
        mode = gpu_only
    }
}
